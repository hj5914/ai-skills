{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BDO State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "objective",
    "size",
    "risk",
    "phase",
    "contract_path",
    "contract_stage",
    "verification_path",
    "handoff_path",
    "surfaces",
    "verification_summary",
    "reviews",
    "clarify_quiz",
    "impact_scan",
    "constraints_detected",
    "delta",
    "memory"
  ],
  "properties": {
    "objective": {
      "type": "string"
    },
    "size": {
      "type": "string",
      "enum": ["XS", "S", "M", "L", "XL"]
    },
    "risk": {
      "type": "string"
    },
    "phase": {
      "type": "string",
      "enum": ["init", "classify", "plan", "contract", "implement", "review", "verify", "deliver", "memory"]
    },
    "contract_path": {
      "type": "string"
    },
    "contract_stage": {
      "type": "string",
      "enum": ["", "lightweight", "full", "what", "how"]
    },
    "verification_path": {
      "type": "string"
    },
    "handoff_path": {
      "type": "string"
    },
    "surfaces": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "copy",
          "config",
          "ui",
          "backend",
          "api",
          "utility",
          "data",
          "auth",
          "payment",
          "migration",
          "external",
          "performance"
        ]
      }
    },
    "verification_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checks", "escalation", "stop_conditions", "evidence", "runtime_evidence", "gaps"],
      "properties": {
        "checks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "escalation": {
          "type": "array",
          "items": { "type": "string" }
        },
        "stop_conditions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "runtime_evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "gaps": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "status", "focus", "findings", "evidence"],
        "properties": {
          "kind": { "type": "string" },
          "status": { "type": "string" },
          "focus": { "type": "string" },
          "findings": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "clarify_quiz": {
      "type": "object",
      "additionalProperties": false,
      "required": ["questions", "assumptions", "resolved"],
      "properties": {
        "questions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "assumptions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "resolved": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "impact_scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targets", "matched_files", "summary", "recommended_size", "notes"],
      "properties": {
        "targets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "matched_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "summary": {
          "type": "string"
        },
        "recommended_size": {
          "type": "string",
          "enum": ["", "XS", "S", "M", "L", "XL"]
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "constraints_detected": {
      "type": "array",
      "items": { "type": "string" }
    },
    "delta": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["added", "removed", "changed", "impact", "summary", "follow_ups"],
        "properties": {
          "added": {
            "type": "array",
            "items": { "type": "string" }
          },
          "removed": {
            "type": "array",
            "items": { "type": "string" }
          },
          "changed": {
            "type": "array",
            "items": { "type": "string" }
          },
          "impact": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "follow_ups": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "memory": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
